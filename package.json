{
  "name": "mql5-transpiler",
  "version": "0.1.0",
  "type": "module",
  "description": "Transpiles MQL5 source into TypeScript and runs the strategy on a pluggable backtest/live engine.",
  "license": "MIT",
  "author": "Miguel",
  "repository": {
    "type": "git",
    "url": "https://github.com/miguelangelo78/mql5-transpiler.git"
  },
  "homepage": "https://github.com/miguelangelo78/mql5-transpiler#readme",
  "keywords": [
    "mql5",
    "metatrader",
    "mt5",
    "transpiler",
    "trading",
    "backtest",
    "expert-advisor"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "ea": "tsx src/cli/run.ts",
    "ea:live": "tsx src/cli/ea-live.ts",
    "poc": "tsx src/cli/poc.ts",
    "poc:rsi": "tsx src/cli/poc-rsi.ts",
    "transpile": "tsx src/cli/transpile.ts",
    "backtest": "tsx src/cli/backtest.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsup",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@tickerall/sdk": "^0.1.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
